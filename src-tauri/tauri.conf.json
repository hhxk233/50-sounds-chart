{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "五十音特訓",
  "version": "0.1.0",
  "identifier": "com.hhxk233.kanatrainer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "五十音特訓",
        "width": 460,
        "height": 820,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "五十音特訓",
    "longDescription": "平假名/片假名/罗马音/读音 随机互测，错题本，发音。"
  }
}
